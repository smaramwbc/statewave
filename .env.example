# ──────────────────────────────────────────────────
# Statewave — Environment Configuration
# Copy to .env and adjust values for your deployment.
# All variables are prefixed STATEWAVE_.
# ──────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────
STATEWAVE_DEBUG=true

# ── Database (PostgreSQL + pgvector) ──────────────
STATEWAVE_DATABASE_URL=postgresql+asyncpg://statewave:statewave@localhost:5432/statewave

# ── Server ────────────────────────────────────────
STATEWAVE_HOST=0.0.0.0
STATEWAVE_PORT=8100

# ── CORS ──────────────────────────────────────────
# JSON array of origins. ["*"] for local dev.
# STATEWAVE_CORS_ORIGINS=["*"]

# ── Authentication ────────────────────────────────
# Set a key to require Bearer-token auth. Leave empty for open access.
# STATEWAVE_API_KEY=

# ── Rate Limiting ─────────────────────────────────
# Requests per minute per client IP. 0 = disabled.
# STATEWAVE_RATE_LIMIT_RPM=0

# ── Compiler ──────────────────────────────────────
STATEWAVE_COMPILER_TYPE=heuristic
# "heuristic" (default, no external calls) or "llm" (uses LiteLLM, requires API key)

# ── Embeddings ────────────────────────────────────
STATEWAVE_EMBEDDING_PROVIDER=stub
# "stub" (hash-based, no API calls), "litellm" (any embedding model), or "none"
# STATEWAVE_EMBEDDING_DIMENSIONS=1536

# ── LiteLLM (provider abstraction — used by compiler + embeddings) ──
# Statewave routes ALL LLM/embedding calls through LiteLLM, which dispatches
# to whichever provider (OpenAI, Anthropic, Azure, Bedrock, Ollama, Cohere,
# Gemini, Mistral, Groq, …) you select via the model identifier.
# See: https://docs.litellm.ai/docs/providers

# Provider-neutral API key — passed through to the provider chosen by the
# model identifier above. For OpenAI use sk-..., for Anthropic sk-ant-..., etc.
# STATEWAVE_LITELLM_API_KEY=

# Chat-completion model — any LiteLLM identifier:
#   gpt-4o-mini, claude-3-haiku-20240307, ollama/llama3, azure/gpt-4, ...
# STATEWAVE_LITELLM_MODEL=gpt-4o-mini

# Embedding model — any LiteLLM-supported embedding model:
#   text-embedding-3-small, cohere/embed-english-v3.0,
#   voyage/voyage-large-2, ollama/mxbai-embed-large, ...
# STATEWAVE_LITELLM_EMBEDDING_MODEL=text-embedding-3-small

# Optional: custom base URL — e.g. http://localhost:11434 for Ollama,
# or a self-hosted OpenAI-compatible gateway.
# STATEWAVE_LITELLM_API_BASE=

# Optional tuning
# STATEWAVE_LITELLM_TIMEOUT_SECONDS=60
# STATEWAVE_LITELLM_MAX_RETRIES=2
# STATEWAVE_LITELLM_TEMPERATURE=0.1

# ── Webhooks ──────────────────────────────────────
# HTTP endpoint for event notifications. Empty = disabled.
# STATEWAVE_WEBHOOK_URL=
# STATEWAVE_WEBHOOK_TIMEOUT=5.0

# ── Multi-tenant (EXPERIMENTAL) ──────────────────
# STATEWAVE_TENANT_HEADER=X-Tenant-ID
# STATEWAVE_REQUIRE_TENANT=false

# ── Token Estimation ─────────────────────────────
# STATEWAVE_TIKTOKEN_MODEL=cl100k_base
# STATEWAVE_DEFAULT_MAX_CONTEXT_TOKENS=4000
